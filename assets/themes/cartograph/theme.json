{
  "$schema": "../../schema/theme.json",
  "name": "Cartograph",
  "version": "3.4.0",
  "contractVersion": 1,
  "styles": [
    "theme.css"
  ],
  "modules": [
    "modules/layout.js",
    "modules/views.js",
    "modules/interactions.js"
  ],
  "views": {
    "post": {
      "module": "modules/views.js",
      "handler": "post"
    },
    "posts": {
      "module": "modules/views.js",
      "handler": "posts"
    },
    "search": {
      "module": "modules/views.js",
      "handler": "search"
    },
    "tab": {
      "module": "modules/views.js",
      "handler": "tab"
    },
    "error": {
      "module": "modules/views.js",
      "handler": "error"
    },
    "loading": {
      "module": "modules/views.js",
      "handler": "loading"
    }
  },
  "regions": {
    "main": {
      "required": true
    },
    "toc": {
      "aliases": [
        "legend"
      ]
    },
    "search": {
      "aliases": [
        "searchBox"
      ]
    },
    "nav": {
      "aliases": [
        "navBox"
      ]
    },
    "tags": {
      "aliases": [
        "tagBand"
      ]
    },
    "footer": {
      "required": true
    },
    "container": {
      "required": true
    },
    "content": {},
    "commandStrip": {},
    "footerNav": {},
    "header": {},
    "legend": {},
    "linksPanel": {},
    "mediaPanel": {},
    "navBox": {},
    "rail": {},
    "routeMap": {},
    "scrollContainer": {},
    "searchBox": {},
    "sidebar": {},
    "tagBand": {},
    "toolsPanel": {},
    "utilities": {
      "aliases": [
        "legend"
      ]
    }
  },
  "components": [
    "nano-search",
    "nano-theme-controls",
    "nano-toc",
    "nano-post-card"
  ],
  "scrollContainer": "region:scrollContainer",
  "configSchema": {
    "type": "object",
    "additionalProperties": true
  },
  "content": {
    "shapes": [
      "rawMarkdown",
      "html",
      "blocks",
      "tocTree",
      "headings",
      "metadata",
      "assets",
      "links"
    ]
  }
}
