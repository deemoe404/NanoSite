{
  "$schema": "../../schema/theme.json",
  "name": "Arcus",
  "version": "3.4.0",
  "contractVersion": 1,
  "styles": [
    "theme.css"
  ],
  "modules": [
    "modules/layout.js",
    "modules/interactions.js"
  ],
  "views": {
    "post": {
      "module": "modules/interactions.js",
      "handler": "post"
    },
    "posts": {
      "module": "modules/interactions.js",
      "handler": "posts"
    },
    "search": {
      "module": "modules/interactions.js",
      "handler": "search"
    },
    "tab": {
      "module": "modules/interactions.js",
      "handler": "tab"
    },
    "error": {
      "module": "modules/interactions.js",
      "handler": "error"
    },
    "loading": {
      "module": "modules/interactions.js",
      "handler": "loading"
    }
  },
  "regions": {
    "main": {
      "required": true
    },
    "toc": {},
    "search": {},
    "nav": {},
    "tags": {},
    "footer": {
      "required": true
    },
    "container": {},
    "content": {},
    "footerNav": {},
    "header": {},
    "rightColumn": {},
    "scrollContainer": {},
    "tagBand": {},
    "toolsPanel": {},
    "utilities": {}
  },
  "components": [
    "nano-search",
    "nano-theme-controls",
    "nano-toc",
    "nano-post-card"
  ],
  "scrollContainer": "region:scrollContainer",
  "configSchema": {
    "type": "object",
    "additionalProperties": true
  },
  "content": {
    "shapes": [
      "rawMarkdown",
      "html",
      "blocks",
      "tocTree",
      "headings",
      "metadata",
      "assets",
      "links"
    ]
  }
}
